fn void loadGlobalCommands(PFN_vkGetInstanceProcAddr gipa) {
   getInstanceProcAddr = gipa;
   vkCreateInstance = (PFN_vkCreateInstance)gipa((Instance)null, "vkCreateInstance");
   vkEnumerateInstanceVersion = (PFN_vkEnumerateInstanceVersion)gipa((Instance)null, "vkEnumerateInstanceVersion");
   vkEnumerateInstanceLayerProperties = (PFN_vkEnumerateInstanceLayerProperties)gipa((Instance)null, "vkEnumerateInstanceLayerProperties");
   vkEnumerateInstanceExtensionProperties = (PFN_vkEnumerateInstanceExtensionProperties)gipa((Instance)null, "vkEnumerateInstanceExtensionProperties");
}

