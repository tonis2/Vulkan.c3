       case ERROR_INITIALIZATION_FAILED: return E_ERROR_INITIALIZATION_FAILED~;
       case ERROR_UNKNOWN: return E_ERROR_UNKNOWN~;
       case ERROR_VALIDATION_FAILED: return E_ERROR_VALIDATION_FAILED~;
  }
}
